{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agent Flow",
  "version": "0.1.0",
  "identifier": "com.fufan.ccflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm prepare:sidecar && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Flow",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": {
      "server-dist": "server-dist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
